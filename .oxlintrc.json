{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "unicorn", "import", "jsx-a11y", "nextjs"],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "eqeqeq": "warn",
    "no-console": "off",
    "no-debugger": "warn",
    "no-unused-vars": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-unused-vars": "error",
    "react/jsx-key": "error",
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "unicorn/no-useless-spread": "error"
  },
  "ignorePatterns": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "out",
    "*.config.js",
    "*.config.ts",
    ".vercel",
    ".vscode",
    "public",
    "playwright-report",
    "test-results"
  ]
}
